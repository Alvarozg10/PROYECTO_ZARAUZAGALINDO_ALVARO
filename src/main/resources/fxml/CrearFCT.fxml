<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="760.0"
            prefWidth="950.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.luisdbb.tarea3AD2024base.controller.CrearFCTController"
            stylesheets="@/styles/app.css">

    <center>

        <StackPane alignment="CENTER">

            <VBox alignment="CENTER"
                  spacing="25"
                  prefWidth="650"
                  maxWidth="650"
                  styleClass="card">

                <Label text="Crear Formación en Empresa">
                    <font>
                        <Font size="26"/>
                    </font>
                </Label>

                <GridPane hgap="20"
                          vgap="18"
                          alignment="CENTER">

                    <columnConstraints>
                        <ColumnConstraints halignment="RIGHT"
                                           prefWidth="180"/>

                        <ColumnConstraints prefWidth="340"/>
                    </columnConstraints>

                    <!-- Alumno -->

                    <Label text="Alumno:"
                           GridPane.rowIndex="0"
                           GridPane.columnIndex="0"/>

                    <ChoiceBox fx:id="cbAlumno"
                               prefWidth="340"
                               GridPane.rowIndex="0"
                               GridPane.columnIndex="1"/>

                    <!-- Tutor -->

                    <Label text="Tutor empresa:"
                           GridPane.rowIndex="1"
                           GridPane.columnIndex="0"/>

                    <ChoiceBox fx:id="cbTutor"
                               prefWidth="340"
                               GridPane.rowIndex="1"
                               GridPane.columnIndex="1"/>

                    <!-- Empresa -->

                    <Label text="Empresa:"
                           GridPane.rowIndex="2"
                           GridPane.columnIndex="0"/>

                    <ChoiceBox fx:id="cbEmpresa"
                               prefWidth="340"
                               GridPane.rowIndex="2"
                               GridPane.columnIndex="1"/>

                    <!-- Fecha inicio -->

                    <Label text="Fecha inicio:"
                           GridPane.rowIndex="3"
                           GridPane.columnIndex="0"/>

                    <DatePicker fx:id="fechaInicio"
                                prefWidth="340"
                                GridPane.rowIndex="3"
                                GridPane.columnIndex="1"/>

                    <!-- Fecha fin -->

                    <Label text="Fecha fin:"
                           GridPane.rowIndex="4"
                           GridPane.columnIndex="0"/>

                    <DatePicker fx:id="fechaFin"
                                prefWidth="340"
                                GridPane.rowIndex="4"
                                GridPane.columnIndex="1"/>

                    <!-- Estado -->

                    <Label text="Estado:"
                           GridPane.rowIndex="5"
                           GridPane.columnIndex="0"/>

                    <ChoiceBox fx:id="cbEstado"
                               prefWidth="340"
                               GridPane.rowIndex="5"
                               GridPane.columnIndex="1"/>

                </GridPane>

                <HBox alignment="CENTER"
                      spacing="20">

                    <Button text="Guardar FE"
                            prefWidth="150"
                            onAction="#guardarFCT"/>

                    <Button text="Volver"
                            prefWidth="130"
                            onAction="#volver"/>

                </HBox>

            </VBox>

        </StackPane>

    </center>

</BorderPane>