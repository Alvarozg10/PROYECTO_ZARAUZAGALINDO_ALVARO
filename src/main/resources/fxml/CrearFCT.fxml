<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="700.0"
            prefWidth="850.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.luisdbb.tarea3AD2024base.controller.CrearFCTController"
            stylesheets="@/styles/app.css">

    <center>

        <StackPane alignment="CENTER">

            <VBox alignment="CENTER"
                  spacing="18"
                  prefWidth="500"
                  prefHeight="560"
                  maxWidth="500"
                  maxHeight="560"
                  styleClass="card">

                <Label text="Crear FE">
                    <font>
                        <Font size="24"/>
                    </font>
                </Label>

                <Label text="Alumno"/>
                <ChoiceBox fx:id="cbAlumno"
                           prefWidth="320"/>

                <Label text="Tutor Empresa"/>
                <ChoiceBox fx:id="cbTutor"
                           prefWidth="320"/>

                <Label text="Empresa"/>
                <TextField fx:id="txtEmpresa"
                           promptText="Nombre empresa"
                           prefWidth="320"/>

                <Label text="Fecha inicio"/>
                <DatePicker fx:id="fechaInicio"
                            prefWidth="320"/>

                <Label text="Fecha fin"/>
                <DatePicker fx:id="fechaFin"
                            prefWidth="320"/>

                <Label text="Estado"/>
                <ChoiceBox fx:id="cbEstado"
                           prefWidth="320"/>

                <HBox alignment="CENTER"
                      spacing="20">

                    <Button text="Guardar"
                            prefWidth="140"
                            onAction="#guardarFCT"/>

                    <Button text="Volver"
                            prefWidth="120"
                            onAction="#volver"/>

                </HBox>

            </VBox>

        </StackPane>

    </center>

</BorderPane>