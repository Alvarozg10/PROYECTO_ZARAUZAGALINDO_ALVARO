<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="400.0" prefWidth="600.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.luisdbb.tarea3AD2024base.controller.CrearFCTController"
            stylesheets="@/styles/app.css">

    <center>
        <StackPane alignment="CENTER">

            <VBox alignment="CENTER"
                  spacing="15"
                  prefWidth="400"
                  maxWidth="400"
                  maxHeight="450"
                  styleClass="card">

                <ScrollPane fitToWidth="true"
                            prefHeight="400"
                            hbarPolicy="NEVER"
                            style="-fx-background-color: transparent;">

                    <VBox spacing="15" alignment="CENTER">

                        <Label text="Crear FCT">
                            <font>
                                <Font size="18"/>
                            </font>
                        </Label>

                        <Label text="Alumno"/>
                        <ChoiceBox fx:id="cbAlumno" prefWidth="250"/>

                        <Label text="Tutor Empresa"/>
                        <ChoiceBox fx:id="cbTutor" prefWidth="250"/>

                        <TextField fx:id="txtEmpresa"
                                   promptText="Nombre empresa"
                                   prefWidth="250"/>

                        <Label text="Fecha inicio"/>
                        <DatePicker fx:id="fechaInicio" prefWidth="250"/>

                        <Label text="Fecha fin"/>
                        <DatePicker fx:id="fechaFin" prefWidth="250"/>

                        <Label text="Estado"/>
                        <ChoiceBox fx:id="cbEstado" prefWidth="250"/>

                        <HBox spacing="15" alignment="CENTER">
                            <Button text="Guardar" onAction="#guardarFCT"/>
                            <Button text="Volver" onAction="#volver"/>
                        </HBox>

                    </VBox>

                </ScrollPane>

            </VBox>

        </StackPane>
    </center>

</BorderPane>