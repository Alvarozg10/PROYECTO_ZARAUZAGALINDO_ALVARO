<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane prefWidth="1000"
            prefHeight="750"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.luisdbb.tarea3AD2024base.controller.DatosFCTAlumnoController"
            stylesheets="@/styles/app.css">

    <center>

        <ScrollPane fitToWidth="true">

            <VBox alignment="CENTER"
                  spacing="25">

                <padding>
                    <Insets top="20" bottom="20"/>
                </padding>

                <VBox spacing="25"
                      maxWidth="700"
                      styleClass="card">

                    <padding>
                        <Insets top="25" right="30"
                                bottom="25" left="30"/>
                    </padding>

                    <Label text="Mi Formación en Empresa">
                        <font>
                            <Font size="28"/>
                        </font>
                    </Label>

                    <!-- DASHBOARD -->

                    <VBox spacing="10">

                        <Label text="PROGRESO FE"
                               style="-fx-font-size:16px;-fx-font-weight:bold;"/>

                        <ProgressBar fx:id="progressFE"
                                     prefWidth="500"/>

                        <Label fx:id="lblPorcentaje"
                               style="-fx-font-size:18px;-fx-font-weight:bold;"/>

                        <GridPane hgap="30" vgap="10">

                            <Label text="Días realizados:"/>
                            <Label fx:id="lblDiasRealizados"
                                   GridPane.columnIndex="1"/>

                            <Label text="Días restantes:"
                                   GridPane.rowIndex="1"/>

                            <Label fx:id="lblDiasRestantes"
                                   GridPane.rowIndex="1"
                                   GridPane.columnIndex="1"/>

                            <Label text="Duración total:"
                                   GridPane.rowIndex="2"/>

                            <Label fx:id="lblDuracionTotal"
                                   GridPane.rowIndex="2"
                                   GridPane.columnIndex="1"/>

                        </GridPane>

                    </VBox>

                    <Separator/>

                    <!-- EMPRESA -->

                    <VBox spacing="10">

                        <Label text="DATOS DE LA EMPRESA"
                               style="-fx-font-size:16px;-fx-font-weight:bold;"/>

                        <GridPane hgap="20" vgap="10">

                            <Label text="Empresa:"/>
                            <Label fx:id="lblEmpresa"
                                   GridPane.columnIndex="1"/>

                            <Label text="Dirección:"
                                   GridPane.rowIndex="1"/>
                            <Label fx:id="lblDireccion"
                                   GridPane.rowIndex="1"
                                   GridPane.columnIndex="1"/>

                            <Label text="Teléfono:"
                                   GridPane.rowIndex="2"/>
                            <Label fx:id="lblTelefonoEmpresa"
                                   GridPane.rowIndex="2"
                                   GridPane.columnIndex="1"/>

                            <Label text="Correo:"
                                   GridPane.rowIndex="3"/>
                            <Label fx:id="lblCorreoEmpresa"
                                   GridPane.rowIndex="3"
                                   GridPane.columnIndex="1"/>

                        </GridPane>

                    </VBox>

                    <Separator/>

                    <!-- TUTOR -->

                    <VBox spacing="10">

                        <Label text="TUTOR DE EMPRESA"
                               style="-fx-font-size:16px;-fx-font-weight:bold;"/>

                        <GridPane hgap="20" vgap="10">

                            <Label text="Tutor:"/>
                            <Label fx:id="lblTutor"
                                   GridPane.columnIndex="1"/>

                            <Label text="Correo:"
                                   GridPane.rowIndex="1"/>
                            <Label fx:id="lblCorreoTutor"
                                   GridPane.rowIndex="1"
                                   GridPane.columnIndex="1"/>

                            <Label text="Teléfono:"
                                   GridPane.rowIndex="2"/>
                            <Label fx:id="lblTelefonoTutor"
                                   GridPane.rowIndex="2"
                                   GridPane.columnIndex="1"/>

                        </GridPane>

                    </VBox>

                    <Separator/>

                    <!-- FE -->

                    <VBox spacing="10">

                        <Label text="DATOS DE LA FE"
                               style="-fx-font-size:16px;-fx-font-weight:bold;"/>

                        <GridPane hgap="20" vgap="10">

                            <Label text="Inicio:"/>
                            <Label fx:id="lblInicio"
                                   GridPane.columnIndex="1"/>

                            <Label text="Fin:"
                                   GridPane.rowIndex="1"/>
                            <Label fx:id="lblFin"
                                   GridPane.rowIndex="1"
                                   GridPane.columnIndex="1"/>

                            <Label text="Estado:"
                                   GridPane.rowIndex="2"/>
                            <Label fx:id="lblEstado"
                                   GridPane.rowIndex="2"
                                   GridPane.columnIndex="1"/>

                        </GridPane>

                    </VBox>

                    <Button text="Volver"
                            prefWidth="150"
                            onAction="#volver"/>

                </VBox>

            </VBox>

        </ScrollPane>

    </center>

</BorderPane>