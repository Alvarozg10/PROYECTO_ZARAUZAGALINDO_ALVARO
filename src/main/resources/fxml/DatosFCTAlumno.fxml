<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="400.0" prefWidth="600.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.luisdbb.tarea3AD2024base.controller.DatosFCTAlumnoController"
            stylesheets="@/styles/app.css">

    <center>
        <StackPane alignment="CENTER">

            <VBox alignment="CENTER"
		      spacing="15"
		      prefWidth="350"
		      maxWidth="350"
		      maxHeight="250"
		      styleClass="card"
		      StackPane.alignment="CENTER">

                <Label text="Mi FCT">
                    <font>
                        <Font size="18"/>
                    </font>
                </Label>

                <Label fx:id="lblEmpresa"/>
                <Label fx:id="lblTutor"/>
                <Label fx:id="lblEmailTutor"/>
                <Label fx:id="lblTelefonoTutor"/>

                <Button text="Volver" onAction="#volver"/>

            </VBox>

        </StackPane>
    </center>

</BorderPane>