<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="760.0"
            prefWidth="850.0"
            stylesheets="@/styles/app.css"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.luisdbb.tarea3AD2024base.controller.ModificarUsuarioController">

    <center>

        <StackPane>

            <VBox alignment="CENTER"
                  spacing="12"
                  prefWidth="550"
                  prefHeight="680"
                  maxWidth="550"
                  maxHeight="680"
                  styleClass="card">

                <Label text="Modificar Usuario">
                    <font>
                        <Font size="22"/>
                    </font>
                </Label>

                <TableView fx:id="tablaUsuarios"
                           prefHeight="160"
                           prefWidth="470">

                    <columns>

                        <TableColumn fx:id="colNombre"
                                     prefWidth="150"
                                     text="Nombre"/>

                        <TableColumn fx:id="colEmail"
                                     prefWidth="220"
                                     text="Email"/>

                        <TableColumn fx:id="colPerfil"
                                     prefWidth="100"
                                     text="Perfil"/>

                    </columns>

                </TableView>

                <Button text="Cargar usuario"
                        prefWidth="180"
                        onAction="#cargarUsuario"/>

                <Separator prefWidth="420"/>

                <!-- FORMULARIO -->
                <TextField fx:id="firstName"
                           prefWidth="320"
                           promptText="Nombre"/>

                <TextField fx:id="lastName"
                           prefWidth="320"
                           promptText="Apellidos"/>

                <TextField fx:id="email"
                           prefWidth="320"
                           promptText="Email"/>

                <TextField fx:id="telefono"
                           prefWidth="320"
                           promptText="Teléfono"/>

                <PasswordField fx:id="password"
                               prefWidth="320"
                               promptText="Contraseña"/>

                <ChoiceBox fx:id="eleccionUsuario"
                           prefWidth="320"/>

                <DatePicker fx:id="dob"
                            prefWidth="320"/>

                <HBox alignment="CENTER"
                      spacing="20">

                    <RadioButton fx:id="rbMale"
                                 text="Male"/>

                    <RadioButton fx:id="rbFemale"
                                 text="Female"/>

                </HBox>

                <HBox alignment="CENTER"
                      spacing="20">

                    <Button text="Guardar cambios"
                            prefWidth="170"
                            onAction="#updateUser"/>

                    <Button text="Volver"
                            prefWidth="120"
                            onAction="#volver"/>

                </HBox>

            </VBox>

        </StackPane>

    </center>

</BorderPane>