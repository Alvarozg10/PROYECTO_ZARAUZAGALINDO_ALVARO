<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="760.0"
            prefWidth="1000.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.luisdbb.tarea3AD2024base.controller.ModificarUsuarioController"
            stylesheets="@/styles/app.css">

    <center>

        <StackPane alignment="CENTER">

            <VBox alignment="CENTER"
                  spacing="20"
                  prefWidth="700"
                  prefHeight="720"
                  maxWidth="700"
                  maxHeight="720"
                  styleClass="card">

                <!-- TÍTULO -->
                <Label text="Modificar Usuario">
                    <font>
                        <Font size="28"/>
                    </font>
                </Label>

                <!-- TABLA -->
                <TableView fx:id="tablaUsuarios"
                           prefHeight="120"
                           prefWidth="620">

                    <columns>

                        <TableColumn fx:id="colNombre"
                                     text="Nombre"
                                     prefWidth="200"/>

                        <TableColumn fx:id="colEmail"
                                     text="Email"
                                     prefWidth="280"/>

                        <TableColumn fx:id="colPerfil"
                                     text="Perfil"
                                     prefWidth="140"/>

                    </columns>

                </TableView>

                <!-- BOTÓN -->
                <Button text="Cargar usuario"
                        prefWidth="220"
                        onAction="#cargarUsuario"/>

                <!-- FORMULARIO -->
                <GridPane hgap="20"
                          vgap="18"
                          alignment="CENTER">

                    <columnConstraints>
                        <ColumnConstraints prefWidth="280"/>
                        <ColumnConstraints prefWidth="280"/>
                    </columnConstraints>

                    <!-- Nombre -->
                    <TextField fx:id="firstName"
                               promptText="Nombre"
                               prefWidth="280"
                               GridPane.rowIndex="0"
                               GridPane.columnIndex="0"/>

                    <!-- Apellidos -->
                    <TextField fx:id="lastName"
                               promptText="Apellidos"
                               prefWidth="280"
                               GridPane.rowIndex="0"
                               GridPane.columnIndex="1"/>

                    <!-- Email -->
                    <TextField fx:id="email"
                               promptText="Email"
                               prefWidth="280"
                               GridPane.rowIndex="1"
                               GridPane.columnIndex="0"/>

                    <!-- Teléfono -->
                    <TextField fx:id="telefono"
                               promptText="Teléfono"
                               prefWidth="280"
                               GridPane.rowIndex="1"
                               GridPane.columnIndex="1"/>

                    <!-- Contraseña -->
                    <PasswordField fx:id="password"
                                   promptText="Contraseña"
                                   prefWidth="280"
                                   GridPane.rowIndex="2"
                                   GridPane.columnIndex="0"/>

                    <!-- Perfil -->
                    <ChoiceBox fx:id="eleccionUsuario"
                               prefWidth="280"
                               GridPane.rowIndex="2"
                               GridPane.columnIndex="1"/>

                    <!-- Fecha -->
                    <DatePicker fx:id="dob"
                                prefWidth="280"
                                GridPane.rowIndex="3"
                                GridPane.columnIndex="0"/>

                    <!-- Sexo -->
                    <HBox alignment="CENTER_LEFT"
                          spacing="20"
                          GridPane.rowIndex="3"
                          GridPane.columnIndex="1">

                        <RadioButton fx:id="rbMale"
                                     text="Hombre"/>

                        <RadioButton fx:id="rbFemale"
                                     text="Mujer"/>

                    </HBox>

                    <!-- Curso -->
                    <VBox spacing="5"
                          GridPane.rowIndex="4"
                          GridPane.columnIndex="0">

                        <Label text="Curso"/>

                        <ChoiceBox fx:id="cbCurso"
                                   prefWidth="280"/>

                    </VBox>

                    <!-- Ciclo -->
                    <VBox spacing="5"
                          GridPane.rowIndex="4"
                          GridPane.columnIndex="1">

                        <Label text="Ciclo"/>

                        <ChoiceBox fx:id="cbCiclo"
                                   prefWidth="280"/>

                    </VBox>

                </GridPane>

                <!-- BOTONES -->
                <HBox alignment="CENTER"
                      spacing="20">

                    <Button text="Guardar cambios"
                            prefWidth="180"
                            onAction="#updateUser"/>

                    <Button text="Volver"
                            prefWidth="140"
                            onAction="#volver"/>

                </HBox>

            </VBox>

        </StackPane>

    </center>

</BorderPane>