<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="400.0" prefWidth="600.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.luisdbb.tarea3AD2024base.controller.ProfesorController"
            stylesheets="@/styles/app.css">

   <center>
      <StackPane alignment="CENTER">

         <VBox alignment="CENTER"
		      spacing="15"
		      prefWidth="350"
		      prefHeight="300"
		      maxWidth="350"
		      maxHeight="300"
		      styleClass="card"
		      StackPane.alignment="CENTER">

            <Label text="Panel Profesor">
               <font>
                  <Font size="18"/>
               </font>
            </Label>

            <Label fx:id="lblProfesor" text="Hola,"/>

            <Label text="¿Qué desea hacer?"/>

            <Button text="Crear FCT"
                    prefWidth="250"
                    onAction="#crearFCT"/>

            <Button text="Consultar FCTs"
                    prefWidth="250"
                    onAction="#abrirGestionFCT"/>

            <Button text="Gestionar estudiantes"
                    prefWidth="250"
                    onAction="#gestionarEstudiantes"/>

            <Button text="Cerrar sesión"
                    prefWidth="250"
                    onAction="#cerrarSesion"/>

         </VBox>

      </StackPane>
   </center>

</BorderPane>