<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="700.0"
            prefWidth="1200.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.luisdbb.tarea3AD2024base.controller.VerEvaluacionesController"
            stylesheets="@/styles/app.css">

    <center>

        <StackPane alignment="CENTER">

            <VBox alignment="CENTER"
                  spacing="25"
                  prefWidth="1100"
                  maxWidth="1100"
                  styleClass="card">

                <Label text="Evaluaciones de Tutores">
                    <font>
                        <Font size="26"/>
                    </font>
                </Label>

                <TableView fx:id="tablaEvaluaciones"
                           prefHeight="450"
                           prefWidth="1050">

                    <columns>

                        <TableColumn fx:id="colAlumno"
                                     text="Alumno"
                                     prefWidth="220"/>

                        <TableColumn fx:id="colEmpresa"
                                     text="Empresa"
                                     prefWidth="180"/>

                        <TableColumn fx:id="colTutor"
                                     text="Tutor Empresa"
                                     prefWidth="220"/>

                        <TableColumn fx:id="colMedia"
                                     text="Media"
                                     prefWidth="100"/>

                        <TableColumn fx:id="colComentario"
                                     text="Comentario"
                                     prefWidth="330"/>

                    </columns>

                </TableView>

                <HBox alignment="CENTER"
                      spacing="20">

                    <Button text="Ver detalles"
                            prefWidth="150"
                            onAction="#verDetalles"/>

                    <Button text="Volver"
                            prefWidth="120"
                            onAction="#volver"/>

                </HBox>

            </VBox>

        </StackPane>

    </center>

</BorderPane>