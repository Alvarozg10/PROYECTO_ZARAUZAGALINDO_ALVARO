<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="700"
            prefWidth="1100"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.luisdbb.tarea3AD2024base.controller.DashboardProfesorController"
            stylesheets="@/styles/app.css">

    <center>

        <StackPane alignment="CENTER">

            <VBox alignment="CENTER"
                  spacing="30"
                  maxWidth="950"
                  styleClass="card">

                <padding>
                    <Insets top="30"
                            right="30"
                            bottom="30"
                            left="30"/>
                </padding>

                <!-- TITULO -->

                <Label text="Dashboard FE">
                    <font>
                        <Font size="30"/>
                    </font>
                </Label>

                <!-- TARJETAS -->

                <GridPane alignment="CENTER"
                          hgap="25"
                          vgap="25">

                    <!-- TOTAL -->

                    <VBox alignment="CENTER"
                          spacing="10"
                          styleClass="card"
                          prefWidth="180"
                          prefHeight="120">

                        <Label text="TOTAL FE"
                               style="-fx-font-size:16px;-fx-font-weight:bold;"/>

                        <Label fx:id="lblTotalFE"
                               style="-fx-font-size:32px;-fx-font-weight:bold;"/>

                    </VBox>

                    <!-- EN CURSO -->

                    <VBox alignment="CENTER"
                          spacing="10"
                          styleClass="card"
                          prefWidth="180"
                          prefHeight="120"
                          GridPane.columnIndex="1">

                        <Label text="EN CURSO"
                               style="-fx-font-size:16px;-fx-font-weight:bold;"/>

                        <Label fx:id="lblEnCurso"
                               style="-fx-font-size:32px;-fx-font-weight:bold;"/>

                    </VBox>

                    <!-- PENDIENTES -->

                    <VBox alignment="CENTER"
                          spacing="10"
                          styleClass="card"
                          prefWidth="180"
                          prefHeight="120"
                          GridPane.columnIndex="2">

                        <Label text="PENDIENTES"
                               style="-fx-font-size:16px;-fx-font-weight:bold;"/>

                        <Label fx:id="lblPendientes"
                               style="-fx-font-size:32px;-fx-font-weight:bold;"/>

                    </VBox>

                    <!-- FINALIZADAS -->

                    <VBox alignment="CENTER"
                          spacing="10"
                          styleClass="card"
                          prefWidth="180"
                          prefHeight="120"
                          GridPane.rowIndex="1">

                        <Label text="FINALIZADAS"
                               style="-fx-font-size:16px;-fx-font-weight:bold;"/>

                        <Label fx:id="lblFinalizadas"
                               style="-fx-font-size:32px;-fx-font-weight:bold;"/>

                    </VBox>

                    <!-- EMPRESAS -->

                    <VBox alignment="CENTER"
                          spacing="10"
                          styleClass="card"
                          prefWidth="180"
                          prefHeight="120"
                          GridPane.rowIndex="1"
                          GridPane.columnIndex="1">

                        <Label text="EMPRESAS"
                               style="-fx-font-size:16px;-fx-font-weight:bold;"/>

                        <Label fx:id="lblEmpresas"
                               style="-fx-font-size:32px;-fx-font-weight:bold;"/>

                    </VBox>

                </GridPane>

                <!-- ESTADÍSTICAS AVANZADAS -->

                <VBox alignment="CENTER"
                      spacing="15"
                      styleClass="card"
                      prefWidth="650">

                    <Label text="Estadísticas Avanzadas"
                           style="-fx-font-size:18px;-fx-font-weight:bold;"/>

                    <Label fx:id="lblEmpresaTop"/>

                    <Label fx:id="lblProximaFinalizacion"/>

                    <Label fx:id="lblFinalizanPronto"/>

                </VBox>

                <!-- BOTÓN -->

                <VBox spacing="10" alignment="CENTER">

			    <Button text="Seguimiento FCT"
			            prefWidth="220"
			            onAction="#abrirSeguimiento"/>
			
			    <Button text="Volver"
			            prefWidth="180"
			            onAction="#volver"/>

                </VBox>
                
            </VBox>

        </StackPane>

    </center>

</BorderPane>