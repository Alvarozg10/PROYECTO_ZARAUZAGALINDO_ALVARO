<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="400.0" prefWidth="600.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.luisdbb.tarea3AD2024base.controller.SubirDocumentoController"
            stylesheets="@/styles/app.css">

    <center>
        <StackPane alignment="CENTER">

            <VBox alignment="CENTER"
                  spacing="15"
                  prefWidth="350"
                  maxWidth="350"
                  maxHeight="300"
                  styleClass="card">

                <Label text="Subir Documento">
                    <font>
                        <Font size="18"/>
                    </font>
                </Label>

                <ChoiceBox fx:id="cbAlumno" prefWidth="250"/>

                <Button text="Seleccionar PDF"
                        prefWidth="200"
                        onAction="#seleccionarArchivo"/>

                <Label fx:id="lblArchivo"
                       text="Ningún archivo seleccionado"
                       wrapText="true"
                       maxWidth="250"/>

                <Button text="Subir"
                        prefWidth="200"
                        onAction="#subirDocumento"/>

                <Button text="Volver"
                        prefWidth="200"
                        onAction="#volver"/>

            </VBox>

        </StackPane>
    </center>

</BorderPane>