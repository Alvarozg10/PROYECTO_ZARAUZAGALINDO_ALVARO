<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="700"
            prefWidth="900"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.luisdbb.tarea3AD2024base.controller.CrearEmpresaController"
            stylesheets="@/styles/app.css">

    <center>

        <StackPane alignment="CENTER">

            <VBox alignment="CENTER"
                  spacing="25"
                  prefWidth="600"
                  maxWidth="600"
                  prefHeight="550"
                  styleClass="card">

                <Label text="Crear Empresa">
                    <font>
                        <Font size="26"/>
                    </font>
                </Label>

                <GridPane hgap="20"
                          vgap="18"
                          alignment="CENTER">

                    <columnConstraints>
                        <ColumnConstraints halignment="RIGHT" prefWidth="170"/>
                        <ColumnConstraints prefWidth="320"/>
                    </columnConstraints>

                    <Label text="Nombre:"
                           GridPane.rowIndex="0"
                           GridPane.columnIndex="0"/>

                    <TextField fx:id="txtNombre"
                               promptText="Nombre empresa"
                               GridPane.rowIndex="0"
                               GridPane.columnIndex="1"/>

                    <Label text="Dirección:"
                           GridPane.rowIndex="1"
                           GridPane.columnIndex="0"/>

                    <TextField fx:id="txtDireccion"
                               promptText="Dirección"
                               GridPane.rowIndex="1"
                               GridPane.columnIndex="1"/>

                    <Label text="Teléfono:"
                           GridPane.rowIndex="2"
                           GridPane.columnIndex="0"/>

                    <TextField fx:id="txtTelefono"
                               promptText="Teléfono"
                               GridPane.rowIndex="2"
                               GridPane.columnIndex="1"/>

                    <Label text="Correo:"
                           GridPane.rowIndex="3"
                           GridPane.columnIndex="0"/>

                    <TextField fx:id="txtCorreo"
                               promptText="correo@empresa.com"
                               GridPane.rowIndex="3"
                               GridPane.columnIndex="1"/>

                </GridPane>

                <HBox alignment="CENTER"
                      spacing="20">

                    <Button text="Guardar"
                            prefWidth="140"
                            onAction="#guardarEmpresa"/>

                    <Button text="Volver"
                            prefWidth="120"
                            onAction="#volver"/>

                </HBox>

            </VBox>

        </StackPane>

    </center>

</BorderPane>